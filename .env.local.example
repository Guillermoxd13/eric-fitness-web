# Price IDs from Stripe → Products
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# ===== Cloudflare Stream =====
# https://dash.cloudflare.com → Stream → right sidebar "Account ID"
CLOUDFLARE_ACCOUNT_ID=
# Stream API token with Stream:Edit permission
CLOUDFLARE_STREAM_API_TOKEN=
# Signing key ID + JWK from `POST /accounts/:id/stream/keys`
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_JWK=

# ===== App =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
