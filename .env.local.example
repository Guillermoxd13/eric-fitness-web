# ===== Stripe (test mode) =====
# Fill with sk_test_... and pk_test_... from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Create with `stripe listen --forward-to localhost:3000/api/stripe/webhook`
